# Identificación del grupo y proyecto
GROUP=grupo6
PROJECT=fluxo

# Puertos (según convención grupo6: 3006 frontend, 4006 backend)
BACKEND_PORT=4006
FRONTEND_PORT=3006

# Base de datos PostgreSQL
DB_IMAGE=postgres:15-alpine
DB_NAME=fluxo
DB_USER=postgres
DB_PASSWORD=CAMBIAR_EN_PRODUCCION

# URL base para producción
BASE_URL=https://fluxo.inf.uach.cl

# ========= NOTIFICACIONES PUSH (Web Push API) =========
# Generar claves VAPID con: npx web-push generate-vapid-keys
# O usar: docker run --rm node:18-alpine npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=TU_CLAVE_PUBLICA_VAPID_AQUI
VAPID_PRIVATE_KEY=TU_CLAVE_PRIVADA_VAPID_AQUI
VAPID_EMAIL=mailto:admin@fluxo.cl

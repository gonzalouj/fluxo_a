# ==========================================
# Configuración de Docker Compose
# ==========================================
# Usado para nombrar contenedores y otros recursos de Docker.
# Cambiar 'fluxo' por el nombre del grupo si es necesario (ej. grupo6).
GROUP=fluxo
PROJECT=fluxo

# Imagen de la base de datos a utilizar.
DB_IMAGE=postgres:15-alpine

# Puertos para desarrollo local. En producción, estos puertos no se exponen
# directamente, sino a través de un proxy inverso como Caddy o Nginx.
BACKEND_PORT=8080
FRONTEND_PORT=80


# ==========================================
# Configuración de la Base de Datos
# ==========================================
# DB_HOST: En Docker, es el nombre del servicio (ej. 'postgres' o 'database').
# DB_PASSWORD: Dejar en blanco para desarrollo local si se usan credenciales genéricas.
#              ¡¡¡ES OBLIGATORIO CAMBIAR ESTO EN PRODUCCIÓN POR UNA CONTRASEÑA SEGURA!!!
DB_HOST=postgres
DB_PORT=5432
DB_NAME=fluxo_db
DB_USER=postgres
DB_PASSWORD=CAMBIAR_EN_PRODUCCION
DB_SSLMODE=disable


# ==========================================
# Configuración del Backend (Aplicación Go)
# ==========================================
# PORT: Puerto INTERNO del contenedor del backend. No cambiar.
PORT=8080

# GIN_MODE: 'debug' para desarrollo, 'release' para producción.
GIN_MODE=debug

# BASE_URL: 'http://localhost' para desarrollo.
#           En producción, cambiar a la URL pública (ej. https://fluxo.inf.uach.cl).
BASE_URL=http://localhost


# ==========================================
# Secretos y Claves de APIs Externas
# ==========================================
# Rellenar con las credenciales obtenidas desde Google Cloud Console.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ==========================================
# Notificaciones Push (Web Push API)
# ==========================================
# Generar claves VAPID para producción con uno de los siguientes comandos:
# 1. npx web-push generate-vapid-keys
# 2. docker run --rm node:18-alpine npx web-push generate-vapid-keys
#
# VAPID_EMAIL: Cambiar por un email de administrador real.
VAPID_PUBLIC_KEY=TU_CLAVE_PUBLICA_VAPID_AQUI
VAPID_PRIVATE_KEY=TU_CLAVE_PRIVADA_VAPID_AQUI
VAPID_EMAIL=mailto:admin@example.com